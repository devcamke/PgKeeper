# Kamal secrets — safe to commit: this file contains only REFERENCES, never
# values. Each line tells Kamal where to find a secret named in
# config/deploy.yml (registry.password and env.secret).
#
# The $VAR form reads your shell environment at deploy time:
#
#   export KAMAL_REGISTRY_PASSWORD=... PGKEEPER_APP1_PASSWORD=... \
#          PGKEEPER_APP2_PASSWORD=... PGKEEPER_WEB_TOKEN=...
#   kamal deploy
#
# Or pull from a password manager instead of the environment — see
# https://kamal-deploy.org/docs/commands/secrets/ (1Password, Bitwarden,
# LastPass, ...), e.g.:
#   SECRETS=$(kamal secrets fetch --adapter 1password --account my --from Vault/PgKeeper \
#     PGKEEPER_APP1_PASSWORD PGKEEPER_WEB_TOKEN KAMAL_REGISTRY_PASSWORD)
#   KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
PGKEEPER_APP1_PASSWORD=$PGKEEPER_APP1_PASSWORD
PGKEEPER_APP2_PASSWORD=$PGKEEPER_APP2_PASSWORD
PGKEEPER_WEB_TOKEN=$PGKEEPER_WEB_TOKEN

