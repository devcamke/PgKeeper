# Secrets for deploy/docker-compose.yml — copy to .env and fill in.
#
#   cp .env.example .env
#   chmod 600 .env
#
# These flow into the container's environment and are interpolated into
# pgkeeper.yml via <%= ENV[...] %>. Never put real values in pgkeeper.yml or
# commit this file once filled in.

# Postgres password for backup_user, per application database
# (add/rename to match the databases: list in pgkeeper.yml and the
# environment: block in docker-compose.yml).
PGKEEPER_APP1_PASSWORD=
PGKEEPER_APP2_PASSWORD=

# Dashboard + remote-API token. Generate with:  openssl rand -hex 32
PGKEEPER_WEB_TOKEN=

# Only needed if you enable the matching blocks in pgkeeper.yml:
# PGKEEPER_ENCRYPTION_PASSPHRASE=
# PGKEEPER_SMTP_PASSWORD=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
