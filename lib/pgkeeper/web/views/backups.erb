<h1>Backups</h1>
<%- @destinations.each do |(name, sets, error, pagination)| -%>
<h2 class="mono"><%= h(name) %></h2>
<%- if error -%>
<%= notice(error, kind: :bad) %>
<%- elsif sets.empty? -%>
<p class="muted">No backups on this destination.</p>
<%- else -%>
<table>
  <tr><th>Database</th><th>Backup</th><th>Kind</th><th>Size</th><th>Pipeline</th>
      <th>Verified</th><th>Download</th></tr>
  <%- sets.each do |set| -%>
  <%- set.artifacts.each_with_index do |artifact, i| -%>
  <tr>
    <td><%= h(set.database) %></td>
    <td class="mono"><%= h(set.label) %></td>
    <td><%= h(artifact.kind) %></td>
    <td><%= h(human_size(artifact.size_bytes)) %></td>
    <td class="mono">
      <%= h([artifact.compression, artifact.encryption].reject { |x| x.to_s == "none" }.join("+")) %>
      <%= "raw" if [artifact.compression, artifact.encryption].all? { |x| x.to_s == "none" } %>
    </td>
    <%- if artifact.verified_at -%>
    <td><%= tip(pill(artifact.verified_tier, "ok"), fmt_time(artifact.verified_at)) %></td>
    <%- else -%>
    <td class="muted">-</td>
    <%- end -%>
    <td>
      <a href="/download?destination=<%= u(name) %>&amp;path=<%= u(artifact.remote_path) %>">artifact</a>
      · <a href="/download?destination=<%= u(name) %>&amp;path=<%= u(artifact.manifest_path) %>">manifest</a>
      <%- if i.zero? -%>
      · <a href="/download-set?destination=<%= u(name) %>&amp;database=<%= u(set.database) %>&amp;timestamp=<%= u(set.label) %>">all&nbsp;(zip)</a>
      <%- end -%>
    </td>
  </tr>
  <%- end -%>
  <%- end -%>
</table>
<%= pager(path: "/backups", unit: "backup sets", state: pagination) %>
<%- end -%>
<%- end -%>
<p class="muted">Restores are deliberately CLI-only — see <span class="mono">docs/RESTORE.md</span>.</p>
