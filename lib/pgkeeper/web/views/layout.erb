<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= h(@title) %> · PgKeeper</title>
<style>
  :root {
    color-scheme: light dark;
    --bg: #f4f6f9;
    --surface: #ffffff;
    --surface-2: #f1f4f8;
    --border: #e4e8ee;
    --border-strong: #d3d9e2;
    --text: #1b2330;
    --muted: #667085;
    --accent: #2f6fed;
    --accent-weak: #2f6fed14;
    --ok: #15925a; --ok-bg: #15925a1a;
    --warn: #b7791f; --warn-bg: #b7791f1f;
    --bad: #d64545; --bad-bg: #d6454518;
    --shadow: 0 1px 2px rgba(16,24,40,0.04), 0 1px 3px rgba(16,24,40,0.06);
    --shadow-lift: 0 4px 12px rgba(16,24,40,0.10);
    --radius: 12px;
    --tip-bg: #1b2330; --tip-fg: #f4f6f9;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --surface-2: #1b222c;
      --border: #262d38;
      --border-strong: #333c48;
      --text: #e6edf3;
      --muted: #97a2b0;
      --accent: #6b8afd;
      --accent-weak: #6b8afd1f;
      --ok: #3fb950; --ok-bg: #3fb95022;
      --warn: #d6a441; --warn-bg: #d6a44122;
      --bad: #f27272; --bad-bg: #f2727222;
      --shadow: 0 1px 2px rgba(0,0,0,0.3);
      --shadow-lift: 0 6px 18px rgba(0,0,0,0.45);
      --tip-bg: #e6edf3; --tip-fg: #0d1117;
    }
  }

  * { box-sizing: border-box; }
  body {
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    margin: 0; line-height: 1.55; color: var(--text); background: var(--bg);
    -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
  }

  header {
    position: sticky; top: 0; z-index: 10;
    display: flex; align-items: center; gap: 1.5rem;
    padding: 0.7rem 1.5rem; flex-wrap: wrap;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  header .brand {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-weight: 700; font-size: 1.08rem; letter-spacing: -0.01em;
  }
  header .brand svg { display: block; }
  nav { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  nav a {
    padding: 0.35rem 0.8rem; border-radius: 8px; font-size: 0.92rem;
    text-decoration: none; color: var(--muted); font-weight: 500;
    transition: background 0.12s, color 0.12s;
  }
  nav a:hover { background: var(--surface-2); color: var(--text); }
  nav a.active { background: var(--accent-weak); color: var(--accent); font-weight: 600; }

  main {
    padding: 1.75rem 1.5rem 3rem; max-width: 74rem; margin: 0 auto;
    animation: rise 0.3s ease both;
  }
  @keyframes rise { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: none; } }
  h1 { font-size: 1.45rem; letter-spacing: -0.02em; margin: 0 0 1.1rem; }
  h2 { font-size: 1.05rem; letter-spacing: -0.01em; margin: 2rem 0 0.6rem; }
  h3 { font-size: 1rem; }

  /* Tables keep their rounded, card-like frame by rounding the corner cells
     rather than clipping with overflow:hidden — so a tooltip can escape the
     table bounds instead of being sheared off at its edge. */
  table {
    border-collapse: separate; border-spacing: 0; width: 100%;
    margin: 0.4rem 0 1rem; font-size: 0.9rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); box-shadow: var(--shadow);
  }
  th, td { text-align: left; padding: 0.6rem 0.85rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
  th {
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;
    font-weight: 600; color: var(--muted); background: var(--surface-2);
    border-bottom: 1px solid var(--border-strong);
  }
  tr:first-child th:first-child, tr:first-child td:first-child { border-top-left-radius: var(--radius); }
  tr:first-child th:last-child,  tr:first-child td:last-child  { border-top-right-radius: var(--radius); }
  tr:last-child td:first-child { border-bottom-left-radius: var(--radius); }
  tr:last-child td:last-child  { border-bottom-right-radius: var(--radius); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--accent-weak); }

  .dot { display: inline-block; width: 0.6rem; height: 0.6rem; border-radius: 50%; }
  .dot-green { background: var(--ok); box-shadow: 0 0 0 3px var(--ok-bg); }
  .dot-yellow { background: var(--warn); box-shadow: 0 0 0 3px var(--warn-bg); }
  .dot-red { background: var(--bad); box-shadow: 0 0 0 3px var(--bad-bg); }

  /* Status pills — a <span class="pill ok"> inside a cell, so the table
     cell itself keeps its normal table-cell layout. */
  .pill {
    display: inline-block; padding: 0.1rem 0.55rem; border-radius: 999px;
    font-size: 0.78rem; font-weight: 600; line-height: 1.55; white-space: nowrap;
  }
  .pill.ok { color: var(--ok); background: var(--ok-bg); }
  .pill.warn { color: var(--warn); background: var(--warn-bg); }
  .pill.bad { color: var(--bad); background: var(--bad-bg); }
  .pill a { color: inherit; text-decoration: none; }
  /* Plain (non-pill) status text keeps just the accent color. */
  .ok { color: var(--ok); } .warn { color: var(--warn); } .bad { color: var(--bad); }

  .muted { color: var(--muted); }
  .mono { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 0.85em; }
  .spark { color: var(--accent); vertical-align: middle; }

  /* Notices & flash banners — one branded family for every status message,
     from the actions-page flash to the retention/backups page notes. */
  .notice {
    display: flex; align-items: flex-start; gap: 0.7rem;
    padding: 0.8rem 0.95rem; margin: 0 0 1.4rem;
    border-radius: 11px; border: 1px solid var(--notice-border);
    background: var(--notice-bg); color: var(--text);
    box-shadow: var(--shadow); position: relative; overflow: hidden;
    animation: notice-in 0.28s cubic-bezier(0.2, 0.7, 0.3, 1) both;
  }
  .notice::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: var(--notice-accent); }
  .notice-icon { flex: none; color: var(--notice-accent); display: grid; place-items: center; margin-top: 0.05rem; }
  .notice-icon svg { width: 1.25rem; height: 1.25rem; }
  .notice-body { flex: 1; font-size: 0.92rem; line-height: 1.5; }
  .notice-close {
    flex: none; color: var(--muted); display: inline-flex; align-items: center;
    padding: 0.2rem; border-radius: 7px; margin: -0.15rem -0.15rem 0 0;
  }
  .notice-close svg { width: 1.05rem; height: 1.05rem; }
  .notice-close:hover { color: var(--text); background: color-mix(in srgb, var(--text) 9%, transparent); text-decoration: none; }
  .notice-ok   { --notice-accent: var(--ok);     --notice-bg: var(--ok-bg);     --notice-border: color-mix(in srgb, var(--ok) 26%, transparent); }
  .notice-warn { --notice-accent: var(--warn);   --notice-bg: var(--warn-bg);   --notice-border: color-mix(in srgb, var(--warn) 26%, transparent); }
  .notice-bad  { --notice-accent: var(--bad);    --notice-bg: var(--bad-bg);    --notice-border: color-mix(in srgb, var(--bad) 26%, transparent); }
  .notice-info { --notice-accent: var(--accent); --notice-bg: var(--accent-weak); --notice-border: color-mix(in srgb, var(--accent) 30%, transparent); }
  @keyframes notice-in { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }

  /* Branded tooltips — replace the OS `title=` bubble with a styled, keyboard-
     reachable popover that appears above the trigger. */
  .tip { position: relative; cursor: help; outline: none; }
  .tip:not(:has(.dot)) { border-bottom: 1px dashed var(--border-strong); }
  .tip::after {
    content: attr(data-tip); position: absolute; left: 50%; bottom: calc(100% + 9px);
    transform: translateX(-50%) translateY(4px);
    background: var(--tip-bg); color: var(--tip-fg);
    padding: 0.35rem 0.6rem; border-radius: 8px; font-size: 0.75rem; font-weight: 500;
    white-space: nowrap; line-height: 1.3; letter-spacing: normal; text-transform: none;
    box-shadow: var(--shadow-lift); z-index: 40; opacity: 0; pointer-events: none;
    transition: opacity 0.14s ease, transform 0.14s ease;
  }
  .tip::before {
    content: ""; position: absolute; left: 50%; bottom: calc(100% + 4px);
    transform: translateX(-50%) translateY(4px);
    border: 5px solid transparent; border-top-color: var(--tip-bg);
    z-index: 41; opacity: 0; pointer-events: none;
    transition: opacity 0.14s ease, transform 0.14s ease;
  }
  .tip:hover::after, .tip:focus-visible::after,
  .tip:hover::before, .tip:focus-visible::before { opacity: 1; transform: translateX(-50%) translateY(0); }
  .tip:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 3px; }

  @media (prefers-reduced-motion: reduce) {
    main, .notice { animation: none; }
    .tip::after, .tip::before { transition: none; }
    .action-card, nav a, button, .btn, form.action { transition: none; }
  }

  label { margin-right: 0.9rem; }

  button, .btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.5rem 1.1rem; border-radius: 8px; border: none; cursor: pointer;
    background: var(--accent); color: #fff; font-weight: 600; font-size: 0.9rem;
    font-family: inherit; text-decoration: none; transition: filter 0.12s, transform 0.05s;
  }
  button:hover, .btn:hover { filter: brightness(1.07); text-decoration: none; }
  button:active, .btn:active { transform: translateY(1px); }
  button.danger, .btn.danger { background: var(--bad); }
  button svg, .btn svg { width: 1rem; height: 1rem; }

  select, input[type="text"] {
    padding: 0.35rem 0.55rem; border-radius: 7px; border: 1px solid var(--border-strong);
    background: var(--surface); color: var(--text); font-family: inherit; font-size: 0.88rem;
  }
  input[type="checkbox"] { accent-color: var(--accent); width: 0.95rem; height: 0.95rem; vertical-align: -2px; }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  pre {
    background: var(--surface-2); border: 1px solid var(--border);
    padding: 0.85rem 1rem; border-radius: 10px; overflow-x: auto; font-size: 0.85rem;
  }

  /* -- Actions page -------------------------------------------------- */
  .lead { color: var(--muted); font-size: 0.93rem; max-width: 62rem; margin: 0 0 1.5rem; }

  .action-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(20.5rem, 1fr));
    gap: 1rem; margin-bottom: 2.25rem;
  }
  .action-card {
    display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.15rem 1.25rem 1.1rem;
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
  }
  .action-card:hover {
    box-shadow: var(--shadow-lift); border-color: var(--border-strong); transform: translateY(-2px);
  }
  .action-head { display: flex; gap: 0.8rem; align-items: flex-start; margin-bottom: 0.7rem; }
  .action-head h3 { margin: 0 0 0.15rem; font-size: 1rem; letter-spacing: -0.01em; }
  .action-head p { margin: 0; font-size: 0.85rem; color: var(--muted); line-height: 1.45; }
  .action-icon {
    flex: none; width: 2.4rem; height: 2.4rem; border-radius: 11px;
    display: grid; place-items: center; background: var(--accent-weak); color: var(--accent);
  }
  .action-icon svg { width: 1.3rem; height: 1.3rem; }
  .action-icon.ok { background: var(--ok-bg); color: var(--ok); }
  .action-icon.warn { background: var(--warn-bg); color: var(--warn); }
  .action-icon.bad { background: var(--bad-bg); color: var(--bad); }

  .field { margin: 0.6rem 0; }
  .field-label { display: block; font-size: 0.78rem; font-weight: 600; margin: 0 0 0.35rem; color: var(--text); }
  .field select { width: 100%; }

  .chip-set { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .chip {
    display: inline-flex; align-items: center; gap: 0.35rem; cursor: pointer; margin: 0;
    padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 0.82rem; line-height: 1.4;
    border: 1px solid var(--border-strong); background: var(--surface-2);
    color: var(--muted); user-select: none; transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  .chip input { position: absolute; opacity: 0; width: 0; height: 0; }
  .chip:hover { border-color: var(--accent); color: var(--text); }
  .chip:has(input:checked) { background: var(--accent-weak); border-color: var(--accent); color: var(--accent); font-weight: 600; }
  .chip.danger:has(input:checked) { background: var(--bad-bg); border-color: var(--bad); color: var(--bad); }
  .chip input:focus-visible + span { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }

  .action-foot {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    margin-top: auto; padding-top: 1rem;
  }

  /* Toggle switch — the confirmation gate, styled but still a plain checkbox. */
  .switch { display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; margin: 0; }
  .switch input { position: absolute; opacity: 0; width: 0; height: 0; }
  .switch .slider {
    flex: none; width: 2.15rem; height: 1.2rem; border-radius: 999px;
    background: var(--border-strong); position: relative; transition: background 0.15s;
  }
  .switch .slider::after {
    content: ""; position: absolute; top: 2px; left: 2px;
    width: calc(1.2rem - 4px); height: calc(1.2rem - 4px); border-radius: 50%;
    background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.35); transition: transform 0.15s;
  }
  .switch input:checked + .slider { background: var(--accent); }
  .switch input:checked + .slider::after { transform: translateX(0.95rem); }
  .switch.danger input:checked + .slider { background: var(--bad); }
  .switch input:focus-visible + .slider { outline: 2px solid var(--accent); outline-offset: 2px; }
  .switch-label { font-size: 0.82rem; color: var(--muted); }

  /* Remote-trigger panel */
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; margin-bottom: 1rem;
  }
  .panel-head { padding: 0.85rem 1.1rem; border-bottom: 1px solid var(--border); }
  .panel-head h2 { margin: 0; }
  .panel-head p { margin: 0.35rem 0 0; font-size: 0.86rem; }
  .panel pre { margin: 0; border: none; border-radius: 0; background: var(--surface-2); }
</style>
</head>
<body>
<header>
  <span class="brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <ellipse cx="12" cy="5.5" rx="7.5" ry="3" fill="var(--accent)"/>
      <path d="M4.5 5.5v6c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3v-6" stroke="var(--accent)" stroke-width="2" fill="none"/>
      <path d="M4.5 11.5v6c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3v-6" stroke="var(--accent)" stroke-width="2" fill="none" opacity="0.55"/>
    </svg>
    PgKeeper
  </span>
  <nav>
    <a href="/" class="<%= @active == 'overview' ? 'active' : '' %>">Overview</a>
    <a href="/runs" class="<%= @active == 'runs' || @active == 'run' ? 'active' : '' %>">Runs</a>
    <a href="/backups" class="<%= @active == 'backups' ? 'active' : '' %>">Backups</a>
    <a href="/retention" class="<%= @active == 'retention' ? 'active' : '' %>">Retention</a>
    <a href="/actions" class="<%= @active == 'actions' ? 'active' : '' %>">Actions</a>
  </nav>
</header>
<main>
<%= @content %>
</main>
</body>
</html>
