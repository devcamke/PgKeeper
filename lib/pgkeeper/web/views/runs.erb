<h1>Run timeline</h1>
<form method="get" action="/runs">
  <label>Database
    <select name="database">
      <option value="">(all)</option>
      <%- @database_names.each do |name| -%>
      <option value="<%= h(name) %>" <%= @database == name ? "selected" : "" %>><%= h(name) %></option>
      <%- end -%>
    </select>
  </label>
  <button type="submit">Filter</button>
</form>
<%- if @runs.empty? -%>
<p class="muted">No runs recorded<%= @database ? " for #{h(@database)}" : "" %>.</p>
<%- else -%>
<table>
  <tr><th>Run</th><th>Database</th><th>Status</th><th>Started</th><th>Duration</th>
      <th>Artifacts</th><th>Size</th><th>Destinations</th></tr>
  <%- @runs.each do |run| -%>
  <tr>
    <td class="mono"><a href="/runs/<%= h(run.run_id) %>"><%= h(run.run_id) %></a></td>
    <td><%= h(run.database) %></td>
    <td><%= status_pill(run.status) %></td>
    <td title="<%= h(run.started_at) %>"><%= h(fmt_time(run.started_at)) %></td>
    <td><%= h(run.duration_seconds) %>s</td>
    <td><%= h(run.artifact_count) %></td>
    <td><%= h(human_size(run.total_bytes)) %></td>
    <td>
      <%- Array(run.destinations).each do |dest| -%>
      <span class="pill <%= dest["status"] == "ok" ? "ok" : "bad" %>"><%= h(dest["name"]) %></span>
      <%- end -%>
    </td>
  </tr>
  <%- end -%>
</table>
<%- end -%>
